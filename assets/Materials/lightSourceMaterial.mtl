newmtl LightSourceMaterial

# Emissive color (glow)
Ke 1.0 1.0 1.0

# Diffuse response (lit by other lights)
Kd 0.5 0.5 0.5

# Ambient response
Ka 0.1 0.1 0.1

# Specular highlight
Ks 0.3 0.3 0.3

# Shininess
Ns 50.0

# Fully opaque
d 1.0

# Illumination model
# 2 = diffuse + specular lighting
# 3 = diffuse + specular + reflective
illum 2
